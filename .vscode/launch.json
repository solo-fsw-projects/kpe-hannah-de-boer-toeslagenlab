{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug current test file",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "address": "127.0.0.1",
            "localRoot": "${workspaceFolder}",
            "remoteRoot": "/app",
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ],
            "restart": true,
            "sourceMaps": true,
            "outFiles": ["${workspaceFolder}/**/*.js"],
            "preLaunchTask": "Start Current Test Debug Container",
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "continueOnAttach": false
        },
        {
            "name": "Debug all tests",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "address": "127.0.0.1",
            "localRoot": "${workspaceFolder}",
            "remoteRoot": "/app",
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ],
            "restart": false,
            "sourceMaps": true,
            "outFiles": ["${workspaceFolder}/**/*.js"],
            "preLaunchTask": "Start Test Debug Container",
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "timeout": 60000
        }
    ]
}
